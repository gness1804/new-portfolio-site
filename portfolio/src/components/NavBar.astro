---
// NavBar: Desktop tab bar + mobile hamburger menu with dark mode toggle
// Props: currentPage identifies the active tab
interface Props {
  currentPage: 'home' | 'portfolio' | 'work-accomplishments' | 'history';
}
const { currentPage } = Astro.props;

const navLinks = [
  { href: '/', label: 'Home', id: 'home' },
  { href: '/portfolio', label: 'Portfolio', id: 'portfolio' },
  { href: '/work-accomplishments', label: 'Work Accomplishments', id: 'work-accomplishments' },
  { href: '/history', label: 'History', id: 'history' },
];
---

<header class="bg-white dark:bg-gray-900 border-b border-gray-200 dark:border-gray-700 sticky top-0 z-50 shadow-sm transition-colors duration-200">
  <div class="max-w-6xl mx-auto px-4">
    <div class="flex items-center justify-between h-16">
      <!-- Logo (top-left) — cat head only, no name text -->
      <div class="flex-shrink-0">
        <a href="/" aria-label="Graham Nessler - Home" class="inline-flex items-center hover:opacity-80 transition-opacity">
          <!-- Cat logo: gray top half, red bottom half, black eyes on gray, whiskers -->
          <svg
            width="52"
            height="52"
            viewBox="0 0 60 60"
            fill="none"
            xmlns="http://www.w3.org/2000/svg"
            aria-hidden="true"
            focusable="false"
          >
            <defs>
              <clipPath id="nav-cat-clip">
                <circle cx="30" cy="36" r="20" />
              </clipPath>
            </defs>
            <!-- Ears: gray triangles, stay within head width -->
            <polygon points="14,22 19,8 24,22" fill="#d1d5db" stroke="#0a0a0a" stroke-width="1.5" stroke-linejoin="round" />
            <polygon points="36,22 41,8 46,22" fill="#d1d5db" stroke="#0a0a0a" stroke-width="1.5" stroke-linejoin="round" />
            <!-- Head: gray top half, red bottom half -->
            <rect x="10" y="16" width="40" height="20" fill="#d1d5db" clip-path="url(#nav-cat-clip)" />
            <rect x="10" y="36" width="40" height="20" fill="#dc2626" clip-path="url(#nav-cat-clip)" />
            <!-- Outline -->
            <circle cx="30" cy="36" r="20" fill="none" stroke="#0a0a0a" stroke-width="1.5" />
            <!-- Eyes: black on gray background -->
            <ellipse cx="23" cy="32" rx="2.5" ry="3" fill="#0a0a0a" />
            <ellipse cx="37" cy="32" rx="2.5" ry="3" fill="#0a0a0a" />
            <!-- Whiskers left -->
            <line x1="8" y1="36" x2="20" y2="38" stroke="#0a0a0a" stroke-width="0.8" stroke-linecap="round" />
            <line x1="7" y1="39" x2="20" y2="39" stroke="#0a0a0a" stroke-width="0.8" stroke-linecap="round" />
            <line x1="8" y1="42" x2="20" y2="40" stroke="#0a0a0a" stroke-width="0.8" stroke-linecap="round" />
            <!-- Whiskers right -->
            <line x1="52" y1="36" x2="40" y2="38" stroke="#0a0a0a" stroke-width="0.8" stroke-linecap="round" />
            <line x1="53" y1="39" x2="40" y2="39" stroke="#0a0a0a" stroke-width="0.8" stroke-linecap="round" />
            <line x1="52" y1="42" x2="40" y2="40" stroke="#0a0a0a" stroke-width="0.8" stroke-linecap="round" />
          </svg>
        </a>
      </div>

      <!-- Right side: desktop nav + dark mode toggle + hamburger -->
      <div class="flex items-center gap-2">
        <!-- Desktop tab navigation -->
        <nav aria-label="Main navigation" class="hidden md:flex">
          <ul class="flex" role="list">
            {navLinks.map((link) => (
              <li>
                <a
                  href={link.href}
                  aria-current={currentPage === link.id ? 'page' : undefined}
                  class={`
                    inline-block px-4 py-5 text-sm font-medium transition-colors
                    border-b-4
                    ${currentPage === link.id
                      ? 'border-red-600 text-gray-900 dark:text-white font-semibold'
                      : 'border-transparent text-gray-600 dark:text-gray-300 hover:text-gray-900 dark:hover:text-white hover:border-gray-300 dark:hover:border-gray-500'}
                  `}
                >
                  {link.label}
                </a>
              </li>
            ))}
          </ul>
        </nav>

        <!-- Dark mode toggle -->
        <button
          id="theme-toggle"
          type="button"
          aria-label="Toggle dark mode"
          class="p-2 rounded-md text-gray-600 dark:text-gray-300 hover:text-gray-900 dark:hover:text-white hover:bg-gray-100 dark:hover:bg-gray-800 focus:outline-none focus:ring-2 focus:ring-red-600 transition-colors"
        >
          <!-- Sun icon (shown in dark mode to switch to light) -->
          <svg id="sun-icon" class="h-5 w-5 hidden" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364-6.364l-.707.707M6.343 17.657l-.707.707M17.657 17.657l-.707-.707M6.343 6.343l-.707-.707M12 8a4 4 0 100 8 4 4 0 000-8z" />
          </svg>
          <!-- Moon icon (shown in light mode to switch to dark) -->
          <svg id="moon-icon" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z" />
          </svg>
        </button>

        <!-- Mobile hamburger button -->
        <button
          id="hamburger-btn"
          type="button"
          aria-expanded="false"
          aria-controls="mobile-menu"
          aria-label="Toggle navigation menu"
          class="md:hidden inline-flex items-center justify-center p-2 rounded-md text-gray-600 dark:text-gray-300 hover:text-gray-900 dark:hover:text-white hover:bg-gray-100 dark:hover:bg-gray-800 focus:outline-none focus:ring-2 focus:ring-red-600 transition-colors"
        >
          <span class="sr-only">Open main menu</span>
          <!-- Hamburger icon -->
          <svg id="hamburger-icon" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
          </svg>
          <!-- Close icon -->
          <svg id="close-icon" class="h-6 w-6" style="display:none;" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
          </svg>
        </button>
      </div>
    </div>

    <!-- Mobile menu (hidden by default) -->
    <nav
      id="mobile-menu"
      aria-label="Mobile navigation"
      style="display:none;"
      class="md:hidden border-t border-gray-200 dark:border-gray-700"
    >
      <ul class="py-2" role="list">
        {navLinks.map((link) => (
          <li>
            <a
              href={link.href}
              aria-current={currentPage === link.id ? 'page' : undefined}
              class={`
                block px-4 py-3 text-sm font-medium transition-colors
                ${currentPage === link.id
                  ? 'bg-red-50 dark:bg-red-950 text-red-700 dark:text-red-400 border-l-4 border-red-600 pl-3'
                  : 'text-gray-600 dark:text-gray-300 hover:bg-gray-50 dark:hover:bg-gray-800 hover:text-gray-900 dark:hover:text-white'}
              `}
            >
              {link.label}
            </a>
          </li>
        ))}
      </ul>
    </nav>
  </div>
</header>

<script>
  // --- Hamburger menu ---
  const btn = document.getElementById('hamburger-btn') as HTMLButtonElement | null;
  const menu = document.getElementById('mobile-menu') as HTMLElement | null;
  const hamburgerIcon = document.getElementById('hamburger-icon') as SVGElement | null;
  const closeIcon = document.getElementById('close-icon') as SVGElement | null;

  function openMenu() {
    if (!menu || !btn || !hamburgerIcon || !closeIcon) return;
    menu.style.display = 'block';
    btn.setAttribute('aria-expanded', 'true');
    hamburgerIcon.style.display = 'none';
    closeIcon.style.display = 'block';
  }

  function closeMenu() {
    if (!menu || !btn || !hamburgerIcon || !closeIcon) return;
    menu.style.display = 'none';
    btn.setAttribute('aria-expanded', 'false');
    hamburgerIcon.style.display = 'block';
    closeIcon.style.display = 'none';
  }

  if (btn && menu) {
    btn.addEventListener('click', (e) => {
      e.stopPropagation();
      const isOpen = menu.style.display !== 'none';
      if (isOpen) {
        closeMenu();
      } else {
        openMenu();
      }
    });

    document.addEventListener('click', (e) => {
      if (menu.style.display !== 'none' && !btn.contains(e.target as Node) && !menu.contains(e.target as Node)) {
        closeMenu();
      }
    });

    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && menu.style.display !== 'none') {
        closeMenu();
        btn.focus();
      }
    });
  }

  // --- Dark mode toggle ---
  const themeToggle = document.getElementById('theme-toggle') as HTMLButtonElement | null;
  const sunIcon = document.getElementById('sun-icon') as SVGElement | null;
  const moonIcon = document.getElementById('moon-icon') as SVGElement | null;

  function applyTheme(dark: boolean) {
    if (dark) {
      document.documentElement.classList.add('dark');
    } else {
      document.documentElement.classList.remove('dark');
    }
    if (sunIcon && moonIcon) {
      sunIcon.style.display = dark ? 'block' : 'none';
      moonIcon.style.display = dark ? 'none' : 'block';
    }
  }

  // Initialize theme: default to dark, but respect saved preference
  const savedTheme = localStorage.getItem('theme');
  const prefersDark = savedTheme === null ? true : savedTheme === 'dark';
  applyTheme(prefersDark);

  if (themeToggle) {
    themeToggle.addEventListener('click', () => {
      const isDark = document.documentElement.classList.contains('dark');
      applyTheme(!isDark);
      localStorage.setItem('theme', !isDark ? 'dark' : 'light');
    });
  }
</script>
