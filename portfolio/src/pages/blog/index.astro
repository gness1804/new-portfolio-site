---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const allPosts = (await getCollection('blog')).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf()
);

const recentPosts = allPosts.slice(0, 5);
const olderPosts = allPosts.slice(5);
---

<BaseLayout title="Blog" currentPage="blog">
  <div class="max-w-6xl mx-auto px-4 py-16">
    <div class="prose-content">
      <h1>Blog</h1>
    </div>

    <div class="mt-8 flex flex-col lg:flex-row gap-12">
      <!-- Main content: all posts in chronological order -->
      <div class="flex-1 min-w-0">
        {allPosts.length === 0 ? (
          <p class="text-gray-600 dark:text-gray-400">No posts yet. Check back soon.</p>
        ) : (
          <div class="space-y-8">
            {allPosts.map((post) => (
              <article class="border-b border-gray-200 dark:border-gray-700 pb-8 last:border-b-0">
                <a href={`/blog/${post.id}`} class="block group">
                  <h2 class="text-xl font-semibold text-gray-900 dark:text-white group-hover:text-red-600 dark:group-hover:text-red-400 transition-colors">
                    {post.data.title}
                  </h2>
                  <time
                    datetime={post.data.date.toISOString()}
                    class="block mt-1 text-sm text-gray-500 dark:text-gray-400"
                  >
                    {post.data.date.toLocaleDateString('en-US', {
                      year: 'numeric',
                      month: 'long',
                      day: 'numeric',
                      timeZone: 'UTC',
                    })}
                  </time>
                  <p class="mt-3 text-gray-600 dark:text-gray-300 leading-relaxed">
                    {post.data.description}
                  </p>
                  {post.data.tags && post.data.tags.length > 0 && (
                    <div class="mt-3 flex flex-wrap gap-2">
                      {post.data.tags.map((tag: string) => (
                        <span class="text-xs px-2 py-1 rounded-full bg-gray-100 dark:bg-gray-800 text-gray-600 dark:text-gray-400">
                          {tag}
                        </span>
                      ))}
                    </div>
                  )}
                  <span class="inline-block mt-3 text-sm font-medium text-red-600 dark:text-red-400 group-hover:underline">
                    Read more &rarr;
                  </span>
                </a>
              </article>
            ))}
          </div>
        )}
      </div>

      <!-- Right sidebar: recent posts -->
      <aside class="lg:w-72 flex-shrink-0" aria-label="Recent posts">
        <div class="lg:sticky lg:top-24">
          <h3 class="text-sm font-semibold uppercase tracking-wider text-gray-500 dark:text-gray-400 mb-4">
            Recent Posts
          </h3>
          <nav>
            <ul class="space-y-3">
              {recentPosts.map((post) => (
                <li>
                  <a
                    href={`/blog/${post.id}`}
                    class="block text-sm text-gray-700 dark:text-gray-300 hover:text-red-600 dark:hover:text-red-400 transition-colors leading-snug"
                  >
                    {post.data.title}
                  </a>
                </li>
              ))}
            </ul>
          </nav>

          {olderPosts.length > 0 && (
            <div class="mt-6" id="sidebar-show-all">
              <button
                type="button"
                id="show-all-posts-btn"
                class="text-sm font-medium text-red-600 dark:text-red-400 hover:underline cursor-pointer"
                aria-expanded="false"
                aria-controls="all-older-posts"
              >
                Show all posts
              </button>
              <ul
                id="all-older-posts"
                class="mt-3 space-y-3"
                style="display: none;"
              >
                {olderPosts.map((post) => (
                  <li>
                    <a
                      href={`/blog/${post.id}`}
                      class="block text-sm text-gray-700 dark:text-gray-300 hover:text-red-600 dark:hover:text-red-400 transition-colors leading-snug"
                    >
                      {post.data.title}
                    </a>
                  </li>
                ))}
              </ul>
            </div>
          )}
        </div>
      </aside>
    </div>
  </div>
</BaseLayout>

<script>
  const showAllBtn = document.getElementById('show-all-posts-btn');
  const olderPostsList = document.getElementById('all-older-posts');

  if (showAllBtn && olderPostsList) {
    showAllBtn.addEventListener('click', () => {
      const isHidden = olderPostsList.style.display === 'none';
      olderPostsList.style.display = isHidden ? 'block' : 'none';
      showAllBtn.textContent = isHidden ? 'Hide older posts' : 'Show all posts';
      showAllBtn.setAttribute('aria-expanded', isHidden ? 'true' : 'false');
    });
  }
</script>
